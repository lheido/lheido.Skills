// FlyingSkillHud.ui
// HUD pour afficher le temps de vol restant ou le cooldown du skill Flying

// Container principal
Group #ScreenContainer {
    Anchor: (Full: 0);
    LayoutMode: Full;

    // Container du HUD
    Group #FlyingHud {
        Anchor: (Bottom: 140, Left: 20, Width: 120, Height: 40);
        Visible: false;
        Background: #1a1a2e(0.85);
        Padding: (Full: 8);
        LayoutMode: CenterMiddle;

        // Timer de vol actif (style vert)
        Group #FlightTimer {
            Anchor: (Full: 0);
            LayoutMode: CenterMiddle;
            Visible: false;

            TimerLabel #FlightTime {
                Anchor: (Full: 0);
                Seconds: 0;
                Direction: CountDown;
                Paused: true;
                Style: (FontSize: 20, TextColor: #00ff88);
            }
        }

        // Timer de cooldown (style orange)
        Group #CooldownTimer {
            Anchor: (Full: 0);
            LayoutMode: CenterMiddle;
            Visible: false;

            TimerLabel #CooldownTime {
                Anchor: (Full: 0);
                Seconds: 0;
                Direction: CountDown;
                Paused: true;
                Style: (FontSize: 20, TextColor: #ff6b35);
            }
        }
    }
}
