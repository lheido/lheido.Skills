// SkillSelectionPage.ui
// Interface de selection de 3 skills actifs
$C = "Common.ui";

Group #Root {
    Anchor: (Full: 0);

    // Fond semi-transparent
    Group #Backdrop {
        Anchor: (Full: 0);
        Background: #0a0a14(0.85);
    }

    // Panneau principal centre
    $C.@DecoratedContainer #MainContainer {
        Anchor: (Width: 420, Height: 420);

        #Title {
            $C.@Title { @Text = "Active Skills"; }
        }

        #Content {
            Group #MainPanel {
                Padding: (Full: 24);
                LayoutMode: Top;

                // Sous-titre descriptif
                Label #Subtitle {
                    Anchor: (Height: 24);
                    Text: "Select up to 3 skills to activate";
                    Style: (FontSize: 12, TextColor: #7878a8, HorizontalAlignment: Center);
                }

                // Espacement
                Group #Spacer1 {
                    Anchor: (Height: 8);
                }

                // Label de section equipes
                Label #ActiveLabel {
                    Anchor: (Height: 24);
                    Text: "EQUIPPED";
                    Style: (FontSize: 14, TextColor: #5a8aff, HorizontalAlignment: Center);
                }

                // Espacement
                Group #Spacer2 {
                    Anchor: (Height: 4);
                }

                // Section des 3 slots actifs
                Group #ActiveSlots {
                    Anchor: (Height: 72);
                    LayoutMode: CenterMiddle;

                    // Slot 0
                    Group #SlotWrapper0 {
                        Anchor: (Width: 68, Height: 68);
                        Background: #1a1a3a;
                        Padding: (Full: 2);

                        ItemSlotButton #Slot0 {
                            Anchor: (Full: 0);
                            Style: (
                                Default: (Background: #252550),
                                Hovered: (Background: #353570),
                                Pressed: (Background: #202045)
                            );

                            ItemSlot #Item {
                                Anchor: (Full: 4);
                            }
                        }
                    }

                    // Slot 1
                    Group #SlotWrapper1 {
                        Anchor: (Width: 68, Height: 68);
                        Background: #1a1a3a;
                        Padding: (Full: 2);

                        ItemSlotButton #Slot1 {
                            Anchor: (Full: 0);
                            Style: (
                                Default: (Background: #252550),
                                Hovered: (Background: #353570),
                                Pressed: (Background: #202045)
                            );

                            ItemSlot #Item {
                                Anchor: (Full: 4);
                            }
                        }
                    }

                    // Slot 2
                    Group #SlotWrapper2 {
                        Anchor: (Width: 68, Height: 68);
                        Background: #1a1a3a;
                        Padding: (Full: 2);

                        ItemSlotButton #Slot2 {
                            Anchor: (Full: 0);
                            Style: (
                                Default: (Background: #252550),
                                Hovered: (Background: #353570),
                                Pressed: (Background: #202045)
                            );

                            ItemSlot #Item {
                                Anchor: (Full: 4);
                            }
                        }
                    }
                }

                // Espacement
                Group #Spacer3 {
                    Anchor: (Height: 12);
                }

                // Separateur
                Group #Separator {
                    Anchor: (Height: 1);
                    Background: #2a2a4e;
                }

                // Espacement
                Group #Spacer4 {
                    Anchor: (Height: 12);
                }

                // Label de section disponibles
                Label #AvailableLabel {
                    Anchor: (Height: 24);
                    Text: "AVAILABLE";
                    Style: (FontSize: 14, TextColor: #78a878, HorizontalAlignment: Center);
                }

                // Espacement
                Group #Spacer5 {
                    Anchor: (Height: 4);
                }

                // Grille de skills (container scrollable)
                Group #SkillsListContainer {
                    Anchor: (Height: 140);
                    Background: #0e0e1e(0.6);
                    Padding: (Full: 4);
                    LayoutMode: Full;

                    // Les lignes seront ajoutées dynamiquement ici
                    Group #SkillsList {
                        Anchor: (Full: 0);
                        LayoutMode: Top;
                    }
                }

                // Message quand aucun skill disponible
                Label #NoSkillsMessage {
                    Anchor: (Height: 24);
                    Text: "No skills available";
                    Style: (FontSize: 12, TextColor: #5a5a7a, HorizontalAlignment: Center);
                    Visible: false;
                }
            }
        }
    }
}

$C.@BackButton {}
