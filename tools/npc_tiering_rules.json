{
  "version": 1,
  "description": "Declarative tiering rules used to transform the unified NPC asset index into balancing-oriented drop tiers for Skill Essence. These rules are descriptive and tunable. They do not depend on hardcoded mob IDs except where a few explicit overrides are helpful.",
  "defaults": {
    "tier": 1,
    "drop_chance": 0.35,
    "base_quantity": 1,
    "flying_bonus": 1,
    "notes": ["Default baseline used when no stronger rule matches."]
  },
  "tier_definitions": {
    "0": {
      "label": "trivial_passive",
      "drop_chance": 0.0,
      "base_quantity": 0,
      "description": "Passive, livestock, critters, or otherwise non-combat fauna that should not meaningfully feed the Skill Essence economy."
    },
    "1": {
      "label": "minor_hostile_or_neutral",
      "drop_chance": 0.35,
      "base_quantity": 1,
      "description": "Small threats, weak vermin, or neutral fauna that can be allowed to drop a small amount."
    },
    "2": {
      "label": "standard_combatant",
      "drop_chance": 1.0,
      "base_quantity": 12,
      "description": "Normal hostile enemies and common combat-capable mobs."
    },
    "3": {
      "label": "elite_or_large_threat",
      "drop_chance": 1.0,
      "base_quantity": 3,
      "description": "Large predators, dangerous specials, void mobs, stronger undead, and elite-class enemies."
    },
    "4": {
      "label": "boss_or_mythic_apex",
      "drop_chance": 1.0,
      "base_quantity": 20,
      "description": "Bosses, apex mythics, and exceptional enemies that should be premium Skill Essence sources."
    }
  },
  "health_quantity_thresholds": [50, 100, 150, 225, 325, 450, 600],
  "health_bonus_rules": [
    {
      "min_health": 0,
      "bonus_quantity": 0
    },
    {
      "min_health": 150,
      "bonus_quantity": 1
    },
    {
      "min_health": 300,
      "bonus_quantity": 2
    },
    {
      "min_health": 500,
      "bonus_quantity": 3
    }
  ],
  "tier_order": [
    "explicit_overrides",
    "boss_and_apex",
    "elite_groups",
    "standard_hostiles",
    "minor_groups",
    "passive_groups"
  ],
  "rules": {
    "explicit_overrides": [
      {
        "name": "dragons_are_boss_tier",
        "match": {
          "npc_ids": ["Dragon"]
        },
        "result": {
          "tier": 4,
          "drop_chance": 1.0,
          "base_quantity": 20,
          "reason": "Explicit apex boss override."
        }
      },
      {
        "name": "yeti_is_boss_like_apex",
        "match": {
          "npc_ids": ["Yeti"]
        },
        "result": {
          "tier": 4,
          "drop_chance": 1.0,
          "base_quantity": 20,
          "reason": "Explicit mythic apex override."
        }
      },
      {
        "name": "toad_rhino_variants_are_elite",
        "match": {
          "npc_ids": ["Toad_Rhino", "Toad_Rhino_Magma"]
        },
        "result": {
          "tier": 3,
          "drop_chance": 1.0,
          "base_quantity": 12,
          "reason": "Large elite creature override."
        }
      },
      {
        "name": "wolves_are_standard_hostiles",
        "match": {
          "npc_ids": ["Wolf"]
        },
        "result": {
          "tier": 2,
          "drop_chance": 1.0,
          "base_quantity": 3,
          "reason": "Wolves should behave like standard hostile predators."
        }
      },
      {
        "name": "snakes_are_minor_hostiles",
        "match": {
          "npc_ids": ["Snake"]
        },
        "result": {
          "tier": 1,
          "drop_chance": 0.5,
          "base_quantity": 1,
          "reason": "Snakes are small hostiles and should stay below standard combatants."
        }
      },
      {
        "name": "sharks_are_standard_hostiles",
        "match": {
          "npc_ids": ["Shark"]
        },
        "result": {
          "tier": 2,
          "drop_chance": 1.0,
          "base_quantity": 12,
          "reason": "Sharks are hostile apex aquatic threats and should reward like standard enemies."
        }
      },
      {
        "name": "trork_chieftain_is_elite",
        "match": {
          "npc_ids": ["Trork_Chieftain"]
        },
        "result": {
          "tier": 3,
          "drop_chance": 1.0,
          "base_quantity": 12,
          "reason": "Trork Chieftain should be treated as an elite hostile."
        }
      },
      {
        "name": "skeleton_praetorian_is_elite",
        "match": {
          "npc_ids": ["Skeleton_Praetorian", "Skeleton_Burnt_Praetorian"]
        },
        "result": {
          "tier": 3,
          "drop_chance": 1.0,
          "base_quantity": 12,
          "reason": "Praetorian skeleton variants should be elevated above regular undead."
        }
      }
    ],
    "boss_and_apex": [
      {
        "name": "boss_family",
        "match": {
          "primary_families": ["Boss"]
        },
        "result": {
          "tier": 4,
          "drop_chance": 1.0,
          "base_quantity": 5,
          "reason": "Primary family indicates boss content."
        }
      },
      {
        "name": "mythic_family",
        "match": {
          "primary_families": ["Mythic"]
        },
        "result": {
          "tier": 3,
          "drop_chance": 1.0,
          "base_quantity": 12,
          "reason": "Mythic mobs are premium essence targets but not all are full boss tier."
        }
      },
      {
        "name": "boss_like_flag",
        "match": {
          "all_flags_true": ["boss_like"]
        },
        "result": {
          "tier": 3,
          "drop_chance": 1.0,
          "base_quantity": 12,
          "reason": "Boss-like flag indicates elite threat but should not override true apex bosses."
        }
      }
    ],
    "elite_groups": [
      {
        "name": "void_family",
        "match": {
          "primary_families": ["Void"]
        },
        "result": {
          "tier": 3,
          "drop_chance": 1.0,
          "base_quantity": 12,
          "reason": "Void enemies should reward strongly."
        }
      },
      {
        "name": "elemental_family",
        "match": {
          "primary_families": ["Elemental"]
        },
        "result": {
          "tier": 3,
          "drop_chance": 1.0,
          "base_quantity": 12,
          "reason": "Elementals and golems are elite combatants."
        }
      },
      {
        "name": "undead_family",
        "match": {
          "primary_families": ["Undead"]
        },
        "result": {
          "tier": 3,
          "drop_chance": 1.0,
          "base_quantity": 12,
          "reason": "Undead enemies are strong, common essence sources."
        }
      },
      {
        "name": "dangerous_flag_cluster",
        "match": {
          "any_flags_true": ["void_like", "undead_like", "elemental_like"]
        },
        "result": {
          "tier": 3,
          "drop_chance": 1.0,
          "base_quantity": 12,
          "reason": "Dangerous special-family flag cluster."
        }
      },
      {
        "name": "large_predator_hostile_combo",
        "match": {
          "all_flags_true": ["predator_like"],
          "all_attitudes": ["HOSTILE"]
        },
        "result": {
          "tier": 3,
          "drop_chance": 1.0,
          "base_quantity": 12,
          "reason": "Hostile predator is stronger than average fauna."
        }
      }
    ],
    "standard_hostiles": [
      {
        "name": "intelligent_family",
        "match": {
          "primary_families": ["Intelligent"]
        },
        "result": {
          "tier": 2,
          "drop_chance": 1.0,
          "base_quantity": 3,
          "reason": "Intelligent hostiles are standard combat mobs."
        }
      },
      {
        "name": "hostile_attitude_default",
        "match": {
          "all_attitudes": ["HOSTILE"]
        },
        "result": {
          "tier": 2,
          "drop_chance": 1.0,
          "base_quantity": 3,
          "reason": "Hostile attitude should reliably drop essence."
        }
      },
      {
        "name": "predator_flag_default",
        "match": {
          "any_flags_true": ["predator_like"]
        },
        "result": {
          "tier": 2,
          "drop_chance": 1.0,
          "base_quantity": 3,
          "reason": "Predator-like mobs should default to standard hostile rewards."
        }
      },
      {
        "name": "predator_family_default",
        "match": {
          "primary_families": ["Predator"]
        },
        "result": {
          "tier": 2,
          "drop_chance": 1.0,
          "base_quantity": 3,
          "reason": "Predators are standard combat-capable mobs."
        }
      },
      {
        "name": "avian_hostile_or_combat_capable",
        "match": {
          "primary_families": ["Avian"],
          "all_attitudes": ["HOSTILE"]
        },
        "result": {
          "tier": 2,
          "drop_chance": 1.0,
          "base_quantity": 3,
          "reason": "Hostile avians should drop like standard enemies."
        }
      }
    ],
    "minor_groups": [
      {
        "name": "vermin_default",
        "match": {
          "primary_families": ["Vermin"]
        },
        "result": {
          "tier": 1,
          "drop_chance": 0.5,
          "base_quantity": 1,
          "reason": "Vermin are minor enemies with low but nonzero rewards."
        }
      },
      {
        "name": "neutral_default",
        "match": {
          "all_attitudes": ["NEUTRAL"]
        },
        "result": {
          "tier": 1,
          "drop_chance": 0.35,
          "base_quantity": 1,
          "reason": "Neutral creatures may drop a small amount."
        }
      },
      {
        "name": "aquatic_non_apex",
        "match": {
          "primary_families": ["Aquatic"]
        },
        "result": {
          "tier": 1,
          "drop_chance": 0.25,
          "base_quantity": 1,
          "reason": "Most aquatic fauna should be low-reward unless explicitly promoted."
        }
      },
      {
        "name": "hostile_aquatic_default",
        "match": {
          "primary_families": ["Aquatic"],
          "all_attitudes": ["HOSTILE"]
        },
        "result": {
          "tier": 2,
          "drop_chance": 1.0,
          "base_quantity": 3,
          "reason": "Hostile aquatic mobs should reward like standard enemies."
        }
      },
      {
        "name": "avian_non_hostile",
        "match": {
          "primary_families": ["Avian"]
        },
        "result": {
          "tier": 1,
          "drop_chance": 0.2,
          "base_quantity": 1,
          "reason": "Most birds should be low-value unless clearly hostile."
        }
      }
    ],
    "passive_groups": [
      {
        "name": "livestock_family",
        "match": {
          "primary_families": ["Livestock"]
        },
        "result": {
          "tier": 0,
          "drop_chance": 0.0,
          "base_quantity": 0,
          "reason": "Livestock should not be a meaningful essence source."
        }
      },
      {
        "name": "critter_family",
        "match": {
          "primary_families": ["Critter"]
        },
        "result": {
          "tier": 0,
          "drop_chance": 0.0,
          "base_quantity": 0,
          "reason": "Critters are too trivial for essence rewards."
        }
      },
      {
        "name": "passive_attitude_default",
        "match": {
          "all_attitudes": ["PASSIVE"]
        },
        "result": {
          "tier": 0,
          "drop_chance": 0.0,
          "base_quantity": 0,
          "reason": "Passive mobs should not feed the progression loop."
        }
      },
      {
        "name": "tamed_animals_are_not_farm_targets",
        "match": {
          "all_flags_true": ["tamed_like"]
        },
        "result": {
          "tier": 0,
          "drop_chance": 0.0,
          "base_quantity": 0,
          "reason": "Tamed variants should not be exploited for essence farming."
        }
      }
    ]
  },
  "post_modifiers": [
    {
      "name": "flying_bonus",
      "enabled": true,
      "match": {
        "all_flags_true": ["flying_like"]
      },
      "effect": {
        "add_quantity": 1
      },
      "reason": "Flying mobs are slightly harder to engage."
    },
    {
      "name": "aquatic_small_bonus_for_hostiles",
      "enabled": true,
      "match": {
        "all_flags_true": ["aquatic_like"],
        "all_attitudes": ["HOSTILE"]
      },
      "effect": {
        "add_quantity": 1
      },
      "reason": "Hostile aquatic mobs can be awkward to fight."
    },
    {
      "name": "boss_and_apex_bonus",
      "enabled": true,
      "match": {
        "any_keywords": ["dragon", "yeti", "praetorian", "chieftain"]
      },
      "effect": {
        "add_quantity": 1
      },
      "reason": "Apex threats should provide a small extra quantity bonus."
    },
    {
      "name": "tamed_zero_floor",
      "enabled": true,
      "match": {
        "all_flags_true": ["tamed_like"]
      },
      "effect": {
        "force_tier": 0,
        "force_drop_chance": 0.0,
        "force_base_quantity": 0
      },
      "reason": "Final safeguard against essence farming from tamed mobs."
    }
  ],
  "validation": {
    "require_known_tiers": true,
    "allowed_tiers": [0, 1, 2, 3, 4],
    "drop_chance_range": {
      "min": 0.0,
      "max": 1.0
    },
    "base_quantity_range": {
      "min": 0,
      "max": 16
    }
  }
}
